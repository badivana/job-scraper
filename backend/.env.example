# .env.example - Copy to .env and fill in values

# App
DEBUG=true
LOG_LEVEL=info
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=changeme-secret-key-change-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days
ALGORITHM=HS256
# Supabase JWT verification (optional if using Supabase Auth)
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/keys
JWT_AUDIENCE=authenticated

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://:password@host:6379/0

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_here

# Apify
APIFY_API_TOKEN=apify_api_token_here

# OpenAI
OPENAI_API_KEY=sk-openai-key-here

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxx
MAIL_FROM=no-reply@jobfinder.example.com

# Sentry (optional)
SENTRY_DSN=https://example@o1.ingest.sentry.io/123456

# Celery (usually same as Redis)
CELERY_BROKER_URL=redis://:password@host:6379/0
CELERY_RESULT_BACKEND=redis://:password@host:6379/1

# File upload limit (bytes)
MAX_CONTENT_LENGTH=5242880  # 5 MB